  (1,'ver_folha_pagamento'),(1,'fechar_caixa'),
  (1,'ver_estoque'),(1,'entrada_mercadoria'),(1,'saida_mercadoria'),
  (1,'ajustar_estoque'),(1,'solicitar_reposicao'),(1,'inventario'),
  (1,'ver_cameras'),(1,'monitorar_ao_vivo'),(1,'ver_historico_acesso'),
  (1,'ver_localizacao'),(1,'exportar_monitoramento'),
