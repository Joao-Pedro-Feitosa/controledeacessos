-- 5. OVERRIDES INDIVIDUAIS — ACL
--    Apenas diferenças em relação ao papel base.
--    permitido = TRUE  → ACL GRANT (permissão extra além do papel)
--    permitido = FALSE → ACL DENY  (remoção de permissão do papel)
--
--    Exemplo: Analista de RH que também pode aprovar despesas:
--    INSERT INTO permissoes_usuario (usuario_id, funcao, permitido) VALUES (4, 'aprovar_despesa', TRUE);
--
--    Exemplo: Gerente sem acesso a fechar caixa:
--    INSERT INTO permissoes_usuario (usuario_id, funcao, permitido) VALUES (2, 'fechar_caixa', FALSE);
CREATE TABLE permissoes_usuario (
  id         SERIAL PRIMARY KEY,
  usuario_id INTEGER NOT NULL REFERENCES usuarios(id) ON DELETE CASCADE,
  funcao     VARCHAR(80) NOT NULL,
  permitido  BOOLEAN NOT NULL DEFAULT TRUE,
  UNIQUE (usuario_id, funcao)
);

-- (sem overrides iniciais — todos usam apenas o papel base)