-- ============================================================
-- SCHEMA: Controle de Acesso Híbrido (RBAC + ACL)
-- Sistema de Gestão de Empresa — versão reestruturada
--
-- ARQUITETURA:
--   RBAC → tabelas: papeis + rbac_permissoes
--          Usuário pertence a um papel; o papel define permissões base.
--          Nenhuma linha extra em permissoes_usuario ao criar usuário.
--
--   ACL  → tabela: permissoes_usuario
--          Overrides individuais sobre a base RBAC.
--          permitido = TRUE  → GRANT (concede mesmo que o papel não tenha)
--          permitido = FALSE → DENY  (nega mesmo que o papel tenha)
--
-- Senha em texto puro para fins de demonstração.
-- ============================================================

-- 1. PAPÉIS (RBAC — identidade do usuário no sistema)
CREATE TABLE papeis (
  id   SERIAL PRIMARY KEY,
  nome VARCHAR(50) UNIQUE NOT NULL
);

INSERT INTO papeis (nome) VALUES
  ('Administrador'),       -- id 1
  ('Gerente'),             -- id 2
  ('Coordenadora'),        -- id 3
  ('Analista de RH'),      -- id 4
  ('Analista de Estoque'), -- id 5
  ('Analista de TI');      -- id 6


-- 2. RECURSOS (usados pelo RBAC genérico — mantido por compatibilidade)
CREATE TABLE recursos (
  id   SERIAL PRIMARY KEY,
  nome VARCHAR(50) UNIQUE NOT NULL
);

INSERT INTO recursos (nome) VALUES
  ('funcionarios'),
  ('relatorios'),
  ('financeiro'),
  ('config');


-- 3. USUÁRIOS
CREATE TABLE usuarios (
  id             SERIAL PRIMARY KEY,
  username       VARCHAR(50) UNIQUE NOT NULL,
  senha          TEXT NOT NULL,
  papel_id       INTEGER NOT NULL REFERENCES papeis(id),
  cargo          VARCHAR(50),          -- espelho de papeis.nome (display)
  primeiro_login BOOLEAN DEFAULT FALSE,
  ativo          BOOLEAN DEFAULT TRUE,
  criado_em      TIMESTAMP DEFAULT NOW()
);

INSERT INTO usuarios (username, senha, papel_id, cargo, primeiro_login) VALUES
  ('admin',        'Admin@123456',    1, 'Administrador',       FALSE),
  ('gerente',      'Gerente@123456',  2, 'Gerente',             FALSE),
  ('coordenadora', 'Coord@123456',    3, 'Coordenadora',        FALSE),
  ('analista_rh',  'RH@1234567',      4, 'Analista de RH',      FALSE),
  ('funcionario',  'Func@1234567',    5, 'Analista de Estoque', FALSE),
  ('analista_ti',  'Ti@12345678',     6, 'Analista de TI',      FALSE);


-- 4. PERMISSÕES POR PAPEL — RBAC
--    Formato: papel_id + funcao (string descritiva, igual ao JS)
--    Ao criar novo usuário, NENHUMA linha é inserida aqui — ele herda do papel.
CREATE TABLE rbac_permissoes (
  id       SERIAL PRIMARY KEY,
  papel_id INTEGER NOT NULL REFERENCES papeis(id) ON DELETE CASCADE,
  funcao   VARCHAR(80) NOT NULL,
  UNIQUE (papel_id, funcao)
);

